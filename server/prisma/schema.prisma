generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String
  password     String?
  avatarUrl    String?
  createdAt    DateTime      @default(now())
  memberships  Membership[]
  activities   Activity[]
  goals        Goal[]
  messages     Message[]
  workoutPlans WorkoutPlan[]
  stats        UserStats[]
}

model Community {
  id               String               @id @default(uuid())
  name             String
  description      String?
  createdAt        DateTime             @default(now())
  memberships      Membership[]
  sharedActivities CommunityActivity[]
  challenges       CommunityChallenge[]
  messages         Message[]
}

model Membership {
  id          String    @id @default(uuid())
  role        String    @default("member")
  joinedAt    DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  community   Community @relation(fields: [communityId], references: [id])
  communityId String

  @@unique([userId, communityId])
}

model Activity {
  id          String              @id @default(uuid())
  type        String
  duration    Int
  notes       String?
  date        DateTime            @default(now())
  user        User                @relation(fields: [userId], references: [id])
  userId      String
  challenge   CommunityChallenge? @relation(fields: [challengeId], references: [id])
  challengeId String?
  sharedTo    CommunityActivity[]
}

model CommunityActivity {
  id          String    @id @default(uuid())
  sharedAt    DateTime  @default(now())
  activity    Activity  @relation(fields: [activityId], references: [id])
  activityId  String
  community   Community @relation(fields: [communityId], references: [id])
  communityId String

  @@unique([activityId, communityId])
}

model CommunityChallenge {
  id          String     @id @default(uuid())
  title       String
  description String?
  type        String
  targetValue Int?
  startsAt    DateTime?
  endsAt      DateTime?
  community   Community  @relation(fields: [communityId], references: [id])
  communityId String
  activities  Activity[]
}

model Message {
  id          String    @id @default(uuid())
  content     String
  sentAt      DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  community   Community @relation(fields: [communityId], references: [id])
  communityId String
}

model Goal {
  id     String @id @default(uuid())
  type   String
  target Int
  user   User   @relation(fields: [userId], references: [id])
  userId String
}

model WorkoutPlan {
  id        String            @id @default(uuid())
  name      String
  createdAt DateTime          @default(now())
  user      User              @relation(fields: [userId], references: [id])
  userId    String
  planned   PlannedActivity[]
}

model PlannedActivity {
  id        String      @id @default(uuid())
  type      String
  dayOfWeek String
  duration  Int
  notes     String?
  plan      WorkoutPlan @relation(fields: [planId], references: [id])
  planId    String
}

model UserStats {
  id            String   @id @default(uuid())
  weekStart     DateTime
  totalMinutes  Int      @default(0)
  totalSessions Int      @default(0)
  streak        Int      @default(0)
  user          User     @relation(fields: [userId], references: [id])
  userId        String
}
